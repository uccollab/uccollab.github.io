---
layout: page
---

{% if page.instructor or page.term or page.location or page.time %}

  {% if page.instructor %}
  <p><strong>Instructor:</strong> {{ page.instructor }}</p>
  {% endif %}

  {% if page.term %}
  <p><strong>Term:</strong> {{ page.term }}</p>
  {% endif %}

  {% if page.location %}
  <p><strong>Location:</strong> {{ page.location }}</p>
  {% endif %}

  {% if page.time %}
  <p><strong>Time:</strong> {{ page.time }}</p>
  {% endif %}

{% endif %}

{{ content }}

{% assign show_materials = false %}
{% if page.schedule %}
  {% for entry in page.schedule %}
    {% if entry.materials and entry.materials.size > 0 %}
      {% assign show_materials = true %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if page.schedule %}
## Schedule

<table class="table table-sm table-borderless">
  <thead>
    <tr>
      <th>Week</th>
      <th>Date</th>
      <th>Topic</th>
      {% if show_materials %}
      <th>Materials</th>
      {% endif %}
    </tr>
  </thead>
  <tbody>
    {% for entry in page.schedule %}
    <tr>
      <td>{{ entry.week }}</td>
      <td>{{ entry.date }}</td>
      <td>
        {% if entry.topic %}
          <strong>{{ entry.topic }}</strong>
        {% endif %}
        {% if entry.description %}
          <div>{{ entry.description | markdownify }}</div>
        {% endif %}
      </td>
      {% if show_materials %}
      <td>
        {% if entry.materials and entry.materials.size > 0 %}
          <ul class="list-unstyled mb-0">
            {% for material in entry.materials %}
            <li>
              {% if material.url %}
                {% if material.url contains '://' %}
                  <a href="{{ material.url }}" target="_blank" rel="noopener noreferrer">{{ material.name }}</a>
                {% else %}
                  <a href="{{ material.url | relative_url }}">{{ material.name }}</a>
                {% endif %}
              {% else %}
                {{ material.name }}
              {% endif %}
            </li>
            {% endfor %}
          </ul>
        {% endif %}
      </td>
      {% endif %}
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}