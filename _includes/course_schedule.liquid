{% assign course = site.teachings | where: 'course_id', include.course_id | first %}
{% if course %}
## {{ course.title }}

{% if course.description %}
{{ course.description | markdownify }}
{% endif %}

{% if course.instructor %}
Instructor: {{ course.instructor }}
{% endif %}

{% if course.term %}
Term: {{ course.term }}
{% endif %}

{% assign show_materials = false %}
{% if course.schedule %}
  {% for entry in course.schedule %}
    {% if entry.materials and entry.materials.size > 0 %}
      {% assign show_materials = true %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if course.schedule %}
<table class="table table-sm table-borderless">
  <thead>
    <tr>
      <th>Week</th>
      <th>Date</th>
      <th>Topic</th>
      {% if show_materials %}
      <th>Materials</th>
      {% endif %}
    </tr>
  </thead>
  <tbody>
    {% for entry in course.schedule %}
    <tr>
      <td>{{ entry.week }}</td>
      <td>{{ entry.date }}</td>
      <td>
        {% if entry.topic %}
          <strong>{{ entry.topic }}</strong>
        {% endif %}
        {% if entry.description %}
          <div>{{ entry.description | markdownify }}</div>
        {% endif %}
      </td>
      {% if show_materials %}
      <td>
        {% if entry.materials and entry.materials.size > 0 %}
          <ul class="list-unstyled mb-0">
            {% for material in entry.materials %}
            <li>
              {% if material.url %}
                <a href="{{ material.url | relative_url }}">{{ material.name }}</a>
              {% else %}
                {{ material.name }}
              {% endif %}
            </li>
            {% endfor %}
          </ul>
        {% endif %}
      </td>
      {% endif %}
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
No schedule available for this course.
{% endif %}

{% endif %}